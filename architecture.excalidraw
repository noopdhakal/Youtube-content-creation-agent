      "text": "YouTube Content Creation YTForge Agent\n(Powered by MCP)\n",
      "fontSize": 34.499840098985594,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "YouTube Content Creation YTForge Agent (Powered by MCP)\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "ems5uyTQvAx78SXb5_GUx",
      "type": "text",
      "x": 127.94062874308389,
      "y": -195.405312928209,
      "width": 1051.891578381578,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aZ",
      "roundness": null,
      "seed": 1421452882,
      "version": 250,
      "versionNonce": 1813654926,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773169508437,
      "link": null,
      "locked": false,
      "text": "YTForge AI is an intelligent content creation agent built on the MCP (Multi-Context Processing)\nframework. It transforms raw ideas, keywords, or briefs into full-fledged video scripts — complete with\ntone, emotion, and structure optimized for storytelling.\n By understanding audience intent, platform trends, and brand voice, StoryForge AI enables creators to\ncraft professional-grade scripts for YouTube, marketing videos, films, and social reels in minutes.\n With its adaptive learning system, it refines its outputs based on feedback, ensuring every story hits the\nmark — clear, concise, and captivating.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "YTForge AI is an intelligent content creation agent built on the MCP (Multi-Context Processing) framework. It transforms raw ideas, keywords, or briefs into full-fledged video scripts — complete with tone, emotion, and structure optimized for storytelling.\n By understanding audience intent, platform trends, and brand voice, StoryForge AI enables creators to craft professional-grade scripts for YouTube, marketing videos, films, and social reels in minutes.\n With its adaptive learning system, it refines its outputs based on feedback, ensuring every story hits the mark — clear, concise, and captivating.\n",
      "autoResize": false,
      "lineHeight": 1.25
    }
  ],
